APP_NAME="backend-portfolio-template"
ENV="local"
LOG_LEVEL="INFO"

# Security
JWT_SECRET="change-me"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Optional seed admin (for demos)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-admin"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/app"
RUN_MIGRATIONS_ON_STARTUP=true

# Redis / Celery (optional; required only for projects that use it)
REDIS_URL="redis://redis:6379/0"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/1"

# AI (optional, OpenAI-compatible)
LLM_ENABLED=false
LLM_PROVIDER="groq"
LLM_API_KEY=""
LLM_BASE_URL="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.1-8b-instant"

# CORS (comma-separated). For portfolio deploys you can safely use "*"
# if you don't need cookies (this template uses Authorization header).
CORS_ORIGINS="http://localhost:5173"

